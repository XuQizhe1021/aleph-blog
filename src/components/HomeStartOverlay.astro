---
import { withBase } from '../utils/paths';

type Props = {
	images: string[];
};

const { images = [] } = Astro.props as Props;
const startImages = images.map((img) => withBase(img));
---

{
	startImages.length ? (
		<section class="home-start-overlay" data-start-overlay aria-label="首页启动图层" data-collapsed="">
			<div class="start-bg">
				<div class="start-image-track" data-start-track>
					<img class="start-image" data-start-image-current alt="首页启动图" />
					<img class="start-image" data-start-image-next alt="" aria-hidden="true" />
				</div>
				<div class="start-mask" aria-hidden="true"></div>
			</div>

			<div class="start-controls" aria-label="启动图切换">
				<button class="start-side-btn left" data-action="prev" type="button" aria-label="上一张">
					<span aria-hidden="true">&#8592;</span>
				</button>
				<button class="start-side-btn right" data-action="next" type="button" aria-label="下一张">
					<span aria-hidden="true">&#8594;</span>
				</button>
			</div>

			<button class="btn start-collapse" data-action="collapse" type="button">上滑收起并进入首页</button>
		</section>
	) : null
}

<script
	is:inline
	define:vars={{ startImages }}
>
	(() => {
		const root = document.querySelector('[data-start-overlay]');
		if (!(root instanceof HTMLElement)) return;
		const currentImageEl = root.querySelector('[data-start-image-current]');
		const nextImageEl = root.querySelector('[data-start-image-next]');
		const track = root.querySelector('[data-start-track]');
		const prevBtn = root.querySelector('button[data-action="prev"]');
		const nextBtn = root.querySelector('button[data-action="next"]');
		const collapseBtn = root.querySelector('button[data-action="collapse"]');
		const html = document.documentElement;
		const source = Array.isArray(startImages) ? startImages.filter(Boolean) : [];
		if (
			!(currentImageEl instanceof HTMLImageElement) ||
			!(nextImageEl instanceof HTMLImageElement) ||
			!(track instanceof HTMLElement) ||
			!source.length
		)
			return;

		let index = Math.floor(Math.random() * source.length);
		let collapsed = false;
		let animating = false;
		let frontImageEl = currentImageEl;
		let backImageEl = nextImageEl;
		const preloadCache = new Set();

		const render = () => {
			frontImageEl.src = source[index];
			frontImageEl.style.transform = 'translateX(0)';
			frontImageEl.style.transition = 'none';
			backImageEl.src = source[index];
			backImageEl.style.transform = 'translateX(100%)';
			backImageEl.style.transition = 'none';
		};

		// 预加载指定索引图片，避免切换时露出底层页面。
		const preloadByIndex = (idx) => {
			if (!source.length) return Promise.resolve();
			const real = (idx + source.length) % source.length;
			const url = source[real];
			if (preloadCache.has(url)) return Promise.resolve();
			return new Promise((resolve) => {
				const img = new Image();
				img.onload = () => {
					preloadCache.add(url);
					resolve();
				};
				img.onerror = () => resolve();
				img.src = url;
			});
		};

		// 始终把当前图左右两侧邻居预加载好，降低切图延迟和闪烁概率。
		const preloadNeighbors = (centerIdx) =>
			Promise.all([
				preloadByIndex(centerIdx),
				preloadByIndex(centerIdx - 1),
				preloadByIndex(centerIdx + 1),
			]);

		const setOverlayState = (nextCollapsed) => {
			collapsed = Boolean(nextCollapsed);
			root.dataset.collapsed = collapsed ? '1' : '';
			if (collapsed) delete html.dataset.startOverlayOpen;
			else html.dataset.startOverlayOpen = '1';
			window.dispatchEvent(
				new CustomEvent('start-overlay:state', {
					detail: { collapsed },
				})
			);
		};

		const switchSlide = async (direction) => {
			if (animating || source.length <= 1) return;
			const nextIndex = (index + direction + source.length) % source.length;
			if (nextIndex === index) return;
			animating = true;
			await preloadByIndex(nextIndex);

			const fromEl = frontImageEl;
			const toEl = backImageEl;
			const enterFrom = direction > 0 ? 100 : -100;
			const leaveTo = direction > 0 ? -100 : 100;

			toEl.src = source[nextIndex];
			toEl.style.transition = 'none';
			fromEl.style.transition = 'none';
			toEl.style.transform = `translateX(${enterFrom}%)`;
			fromEl.style.transform = 'translateX(0)';
			track.offsetWidth;

			toEl.style.transition = 'transform 420ms ease';
			fromEl.style.transition = 'transform 420ms ease';
			toEl.style.transform = 'translateX(0)';
			fromEl.style.transform = `translateX(${leaveTo}%)`;

			const onDone = () => {
				toEl.removeEventListener('transitionend', onDone);
				index = nextIndex;
				frontImageEl = toEl;
				backImageEl = fromEl;
				backImageEl.style.transition = 'none';
				backImageEl.style.transform = `translateX(${enterFrom}%)`;
				animating = false;
				void preloadNeighbors(index);
			};
			toEl.addEventListener('transitionend', onDone);
		};

		prevBtn?.addEventListener('click', () => switchSlide(-1));
		nextBtn?.addEventListener('click', () => switchSlide(1));

		collapseBtn?.addEventListener('click', () => setOverlayState(true));

		window.addEventListener('keydown', (e) => {
			if (collapsed) return;
			if (e.key === 'ArrowLeft') switchSlide(-1);
			if (e.key === 'ArrowRight') switchSlide(1);
			if (e.key === 'Escape') setOverlayState(true);
		});

		window.addEventListener('start-overlay:toggle', (e) => {
			const open = Boolean(e?.detail?.open);
			setOverlayState(!open);
		});

		render();
		void preloadNeighbors(index);
		setOverlayState(false);
	})();
</script>

<style>
	:global(html[data-start-overlay-open='1']) body {
		overflow: hidden;
	}

	.home-start-overlay {
		position: fixed;
		inset: 0;
		z-index: 320;
		display: grid;
		grid-template-rows: auto 1fr auto;
		transition:
			transform 420ms ease,
			opacity 320ms ease,
			visibility 320ms ease;
	}

	.home-start-overlay[data-collapsed='1'] {
		transform: translateY(-100%);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.start-bg {
		position: absolute;
		inset: 0;
	}

	.start-image-track {
		position: absolute;
		inset: 0;
		overflow: hidden;
		background: #0b1020;
	}

	.start-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		will-change: transform;
	}

	.start-mask {
		position: absolute;
		inset: 0;
		z-index: 2;
		background:
			linear-gradient(to bottom, rgba(6, 7, 10, 0.58), rgba(6, 7, 10, 0.15) 30%, rgba(6, 7, 10, 0.68)),
			radial-gradient(circle at 20% 22%, rgba(124, 58, 237, 0.3), transparent 36%);
	}

	.start-controls {
		position: absolute;
		inset: 0;
		z-index: 4;
		pointer-events: none;
	}

	.start-side-btn {
		position: absolute;
		top: 50%;
		width: 48px;
		height: 48px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.34);
		background: linear-gradient(
			145deg,
			rgba(255, 255, 255, 0.24),
			rgba(255, 255, 255, 0.08)
		);
		backdrop-filter: blur(18px) saturate(1.18);
		box-shadow:
			0 8px 28px rgba(0, 0, 0, 0.25),
			inset 0 1px 0 rgba(255, 255, 255, 0.34);
		color: var(--text);
		font-size: 20px;
		line-height: 1;
		transform: translateY(-50%);
		cursor: pointer;
		pointer-events: auto;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.start-side-btn.left {
		left: 16px;
	}

	.start-side-btn.right {
		right: 16px;
	}

	.start-side-btn:hover {
		border-color: rgba(255, 255, 255, 0.62);
		background: linear-gradient(
			145deg,
			rgba(255, 255, 255, 0.32),
			rgba(255, 255, 255, 0.14)
		);
		transform: translateY(-50%) scale(1.04);
	}

	.start-collapse {
		position: relative;
		z-index: 2;
		align-self: end;
		justify-self: center;
		margin-bottom: 26px;
		height: 42px;
		padding: 0 18px;
		background: color-mix(in oklab, var(--panel-strong), transparent 8%);
		backdrop-filter: blur(8px);
	}

	@media (max-width: 720px) {
		.start-side-btn {
			width: 42px;
			height: 42px;
			font-size: 18px;
		}
		.start-side-btn.left {
			left: 8px;
		}
		.start-side-btn.right {
			right: 8px;
		}
	}
</style>
