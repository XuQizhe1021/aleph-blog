---
import { siteConfig } from '../site.config';
import { withBase } from '../utils/paths';
import fssync from 'node:fs';
import path from 'node:path';

const projectRoot = process.cwd();
const publicDir = path.join(projectRoot, 'public');
let rewardImagePath: string = siteConfig.rewardImagePath;
try {
	const files = fssync.readdirSync(publicDir).filter((f) => /^reward\./i.test(f));
	files.sort((a, b) => a.localeCompare(b));
	if (files[0]) rewardImagePath = `/${files[0]}`;
} catch {}
---

<aside class="reward" data-reward-panel aria-label="打赏面板">
	<button class="btn reward-toggle" type="button" data-reward-toggle>打赏</button>
	<div class="reward-card panel" data-reward-card hidden>
		<div class="reward-title">感谢支持</div>
		<img
			data-reward-image
			class="reward-image"
			src={withBase(rewardImagePath)}
			alt="打赏二维码"
			loading="lazy"
		/>
		<div class="reward-fallback muted" data-reward-fallback hidden>未配置打赏图片</div>
	</div>
	<script is:inline>
		(() => {
			const key = 'reward_open';
			const readOpen = () => {
				try {
					return localStorage.getItem(key) === '1';
				} catch {
					return false;
				}
			};
			const writeOpen = (open) => {
				try {
					localStorage.setItem(key, open ? '1' : '0');
				} catch {}
			};

			const state = window.__SITE_REWARD_STATE__ || { open: readOpen() };
			const syncDom = () => {
				document.querySelectorAll('[data-reward-card]').forEach((card) => {
					card.hidden = !state.open;
				});
			};
			const setOpen = (open, persist = true) => {
				state.open = Boolean(open);
				syncDom();
				if (persist) writeOpen(state.open);
			};
			const bindImageFallback = () => {
				document.querySelectorAll('[data-reward-image]').forEach((img) => {
					if (!(img instanceof HTMLImageElement)) return;
					if (img.dataset.rewardBound === '1') return;
					img.dataset.rewardBound = '1';
					// 仅在图片加载失败时显示兜底文案，避免面板空白。
					img.addEventListener('error', () => {
						img.style.display = 'none';
						const panel = img.closest('[data-reward-panel]');
						panel?.querySelectorAll('[data-reward-fallback]').forEach((el) => {
							el.hidden = false;
						});
						if (panel instanceof HTMLElement) panel.style.display = '';
					});
				});
			};

			if (!window.__SITE_REWARD_BINDED__) {
				window.__SITE_REWARD_BINDED__ = true;
				// 使用事件委托，确保 Astro 切页后新按钮仍可响应点击。
				document.addEventListener('click', (event) => {
					const target = event.target;
					if (!(target instanceof Element)) return;
					if (!target.closest('[data-reward-toggle]')) return;
					setOpen(!state.open);
				});
				document.addEventListener('astro:page-load', () => {
					syncDom();
					bindImageFallback();
				});
			}

			window.__SITE_REWARD_STATE__ = state;
			setOpen(state.open, false);
			bindImageFallback();
		})();
	</script>
</aside>

<style>
	.reward {
		position: fixed;
		right: 18px;
		bottom: 18px;
		display: grid;
		gap: 10px;
		z-index: 120;
	}

	.reward-toggle {
		justify-content: center;
	}

	.reward-card {
		width: 220px;
		padding: 12px;
	}

	.reward-title {
		font-size: 13px;
		color: var(--muted);
		margin-bottom: 10px;
	}

	.reward-image {
		width: 100%;
		height: auto;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 10%);
	}

	.reward-fallback {
		font-size: 13px;
		padding: 12px 2px 4px;
	}

	@media (max-width: 720px) {
		.reward {
			right: 12px;
			bottom: 12px;
		}
	}
</style>
