---
import { getSiteSettings } from '../config/site-settings';

const settings = await getSiteSettings();
---

{
	settings.site_features.tools.sidebar ? (
		<aside
			class="site-sidebar panel"
			data-sidebar
			data-collapsed={settings.site_theme_tweaks.sidebarDefaultCollapsed ? '1' : '0'}
		>
			<button class="btn sidebar-toggle" type="button" data-sidebar-toggle>
				{settings.site_texts.sidebarTitle}
			</button>
			<div class="sidebar-body">
				<div class="sidebar-row">
					<div class="muted">{settings.site_texts.sidebarStatusLabel}</div>
					<div class="badge">{settings.site_texts.sidebarStatusValue}</div>
				</div>
				<div class="sidebar-row">
					<div class="muted">{settings.site_texts.sidebarActivityLabel}</div>
					<div class="muted">{settings.site_texts.sidebarActivityHint}</div>
				</div>
			</div>
		</aside>
	) : null
}

<script is:inline>
	(() => {
		const root = document.querySelector('[data-sidebar]');
		if (!(root instanceof HTMLElement)) return;
		const btn = root.querySelector('[data-sidebar-toggle]');
		if (!(btn instanceof HTMLButtonElement)) return;
		const setCollapsed = (collapsed) => {
			root.dataset.collapsed = collapsed ? '1' : '0';
			localStorage.setItem('site_sidebar_collapsed', collapsed ? '1' : '0');
		};
		const initial = localStorage.getItem('site_sidebar_collapsed');
		if (initial === '0' || initial === '1') setCollapsed(initial === '1');
		btn.addEventListener('click', () => setCollapsed(root.dataset.collapsed !== '1'));
	})();
</script>

<style>
	.site-sidebar {
		position: fixed;
		left: 12px;
		bottom: 80px;
		width: min(300px, calc(100vw - 24px));
		padding: 10px;
		z-index: 40;
		transition: transform 220ms ease;
	}

	.site-sidebar[data-collapsed='1'] {
		transform: translateX(calc(-100% + 110px));
	}

	.sidebar-toggle {
		width: 100%;
		justify-content: center;
	}

	.sidebar-body {
		display: grid;
		gap: 10px;
		margin-top: 10px;
	}

	.sidebar-row {
		display: grid;
		gap: 6px;
		padding: 10px;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 22%);
	}

	@media (max-width: 980px) {
		.site-sidebar {
			left: auto;
			right: 12px;
			bottom: 70px;
		}
		.site-sidebar[data-collapsed='1'] {
			transform: translateX(calc(100% - 110px));
		}
	}
</style>

