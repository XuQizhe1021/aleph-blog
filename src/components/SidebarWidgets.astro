---
import { getSiteSettings } from '../config/site-settings';
import { withBase } from '../utils/paths';

const settings = await getSiteSettings();
---

{
	settings.site_features.tools.sidebar ? (
		<>
			<button class="btn sidebar-launcher" type="button" data-sidebar-launcher>
				{settings.site_texts.sidebarTitle}
			</button>
			<aside
				class="site-sidebar panel"
				data-sidebar
				data-open={settings.site_theme_tweaks.sidebarDefaultCollapsed ? '0' : '1'}
				aria-hidden={settings.site_theme_tweaks.sidebarDefaultCollapsed ? 'true' : 'false'}
			>
				<div class="sidebar-head">
					<div class="sidebar-title">{settings.site_texts.sidebarTitle}</div>
					<button class="btn sidebar-close" type="button" data-sidebar-close>关闭</button>
				</div>
				<div class="sidebar-body">
					<div class="sidebar-row">
						<div class="muted">{settings.site_texts.sidebarStatusLabel}</div>
						<div class="badge">{settings.site_texts.sidebarStatusValue}</div>
					</div>
					{
						settings.site_features.tools.timeMachine ? (
							<div class="sidebar-row">
								<div class="muted">快捷入口</div>
								<a class="sidebar-link" href={withBase('/time-machine')}>时光机</a>
							</div>
						) : null
					}
					<div class="sidebar-row">
						<div class="muted">{settings.site_texts.sidebarActivityLabel}</div>
						<div class="muted">{settings.site_texts.sidebarActivityHint}</div>
					</div>
				</div>
			</aside>
		</>
	) : null
}

<style>
	.sidebar-launcher {
		position: fixed;
		left: 12px;
		top: calc(var(--site-header-height, 62px) + 12px);
		z-index: 39;
	}

	.site-sidebar {
		position: fixed;
		top: var(--site-header-height, 62px);
		left: 0;
		height: calc(100dvh - var(--site-header-height, 62px));
		width: min(220px, calc(100vw - 20px));
		padding: 12px;
		border-radius: 0;
		border-right: 1px solid var(--border);
		border-top: 0;
		border-bottom: 0;
		border-left: 0;
		z-index: 41;
		transform: translateX(-110%);
		transition: transform 260ms ease;
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 10px;
		overflow: auto;
	}

	html[data-sidebar-open='1'] .site-sidebar {
		transform: translateX(0);
	}

	.sidebar-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
	}

	.sidebar-title {
		font-weight: 700;
	}

	.sidebar-body {
		display: grid;
		gap: 10px;
		align-content: start;
	}

	.sidebar-row {
		display: grid;
		gap: 6px;
		padding: 10px;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 22%);
	}

	.sidebar-link {
		display: inline-flex;
		align-items: center;
		height: 34px;
		padding: 0 12px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 15%);
		text-decoration: none;
	}

	.sidebar-link:hover {
		border-color: color-mix(in oklab, var(--accent), var(--border) 35%);
		text-decoration: none;
	}

	@media (max-width: 980px) {
		.sidebar-launcher {
			top: calc(var(--site-header-height, 62px) + 10px);
		}
		.site-sidebar {
			width: min(200px, calc(100vw - 10px));
		}
	}
</style>
