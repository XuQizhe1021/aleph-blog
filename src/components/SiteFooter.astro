---
import { siteConfig } from '../site.config';
import RandomPostLink from './RandomPostLink.astro';
import { getSiteSettings } from '../config/site-settings';

const settings = await getSiteSettings();
const now = new Date();
const hour = now.getHours();
const t = settings.site_theme_tweaks;
const texts = settings.site_texts;
let greeting = texts.greetingNight;
if (hour < t.greetingMorningEndHour) greeting = texts.greetingMorning;
else if (hour < t.greetingNoonEndHour) greeting = texts.greetingNoon;
else if (hour < t.greetingAfternoonEndHour) greeting = texts.greetingAfternoon;
else if (hour < t.greetingEveningEndHour) greeting = texts.greetingEvening;
---

<footer class="site-footer">
	<div class="inner muted" data-footer-root>
		<span>© {new Date().getFullYear()} {siteConfig.author}</span>
		{settings.site_features.visual.dynamicFooterGreeting ? <span>{greeting}</span> : null}
		<span>{texts.footerSignature}</span>
		{settings.site_features.tools.siteUptime ? <span data-site-uptime>运行中...</span> : null}
		{
			settings.site_features.tools.randomPost ? (
				<RandomPostLink className="random-link" label={texts.randomPostLabel} />
			) : null
		}
	</div>
</footer>

<script is:inline define:vars={{ settings }}>
	(() => {
		if (!settings?.site_features?.tools?.siteUptime) return;
		const start = new Date(settings.site_theme_tweaks.uptimeStartAt).getTime();
		if (!Number.isFinite(start)) return;

		const formatText = () => {
			const diff = Math.max(0, Date.now() - start);
			const totalSec = Math.floor(diff / 1000);
			const day = Math.floor(totalSec / 86400);
			const hour = Math.floor((totalSec % 86400) / 3600);
			const min = Math.floor((totalSec % 3600) / 60);
			return `运行 ${day}天 ${hour}小时 ${min}分钟`;
		};

		const syncMounts = () => {
			const text = formatText();
			document.querySelectorAll('[data-site-uptime]').forEach((el) => {
				el.textContent = text;
			});
		};

		if (!window.__SITE_UPTIME__) {
			window.__SITE_UPTIME__ = {
				start,
				timer: null,
			};
		}

		if (!window.__SITE_UPTIME_BINDED__) {
			window.__SITE_UPTIME_BINDED__ = true;
			// 切页后页脚节点会替换，这里每次 page-load 都重新同步到新节点。
			document.addEventListener('astro:page-load', syncMounts);
		}

		if (!window.__SITE_UPTIME__.timer) {
			window.__SITE_UPTIME__.timer = window.setInterval(syncMounts, 10000);
		}

		syncMounts();
	})();
</script>

<style>
	.site-footer {
		border-top: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 30%);
		backdrop-filter: blur(16px);
	}

	.inner {
		width: min(1140px, calc(100% - 32px));
		margin: 0 auto;
		min-height: 58px;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 10px;
		padding: 10px 0;
	}

	.random-link {
		color: var(--muted);
	}

	.random-link:hover {
		color: var(--text);
	}

</style>

