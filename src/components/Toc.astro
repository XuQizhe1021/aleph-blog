---
type Heading = { depth: number; slug: string; text: string };
type Props = { headings: Heading[]; variant?: 'sidebar' | 'drawer' | 'floating' };

const { headings, variant = 'sidebar' } = Astro.props;
const visible = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---

{variant === 'drawer' ? (
	<section class="toc-drawer panel" aria-label="目录" data-open="0" data-toc-mode="drawer" data-toc-root>
		<button class="toc-drawer-head" type="button" aria-expanded="false" data-toc-toggle>
			<span class="toc-title">目录</span>
			<span class="chev" aria-hidden="true">⌄</span>
		</button>
		<div class="toc-body-wrap" data-toc-panel>
			<nav class="toc-body">
				{visible.length ? (
					<ul>
						{visible.map((h) => (
							<li class={`d${h.depth}`}>
								<a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
							</li>
						))}
					</ul>
				) : (
					<div class="muted empty">无标题</div>
				)}
			</nav>
		</div>
	</section>
) : variant === 'floating' ? (
	<section class="toc-float" aria-label="目录" data-open="0" data-toc-mode="floating" data-toc-root>
		<button class="toc-float-btn" type="button" aria-expanded="false" data-toc-toggle>
			<span class="toc-float-btn-text">目录</span>
		</button>
		<div class="toc-float-panel panel" aria-hidden="true" data-toc-panel>
			<div class="toc-float-head">
				<div class="toc-title">目录</div>
				<button class="btn toc-float-close" type="button" data-toc-close>关闭</button>
			</div>
			<nav class="toc-body">
				{visible.length ? (
					<ul>
						{visible.map((h) => (
							<li class={`d${h.depth}`}>
								<a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
							</li>
						))}
					</ul>
				) : (
					<div class="muted empty">无标题</div>
				)}
			</nav>
		</div>
	</section>
) : (
	<aside class="toc panel" aria-label="目录" data-toc-root>
		<div class="toc-head">
			<div class="toc-title">目录</div>
		</div>
		<nav class="toc-body">
			{visible.length ? (
				<ul>
					{visible.map((h) => (
						<li class={`d${h.depth}`}>
							<a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
						</li>
					))}
				</ul>
			) : (
				<div class="muted empty">无标题</div>
			)}
		</nav>
	</aside>
)}

<style>
	.toc {
		padding: 14px;
		position: sticky;
		top: 78px;
		max-height: calc(100vh - 110px);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.toc-drawer {
		padding: 12px 14px;
		position: sticky;
		top: var(--site-header-height, 72px);
		z-index: 90;
		background: color-mix(in oklab, var(--panel-strong), transparent 20%);
		backdrop-filter: blur(16px);
	}

	.toc-drawer-head {
		width: 100%;
		cursor: pointer;
		border: 0;
		background: transparent;
		color: inherit;
		padding: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
	}

	.chev {
		opacity: 0.7;
		transition: transform 220ms ease;
	}

	.toc-body-wrap {
		overflow: hidden;
		max-height: 0;
		transition: max-height 260ms ease;
	}

	.toc-drawer[data-open='1'] .toc-body-wrap {
		margin-top: 10px;
	}

	.toc-drawer[data-open='1'] .chev {
		transform: rotate(180deg);
	}

	.toc-head {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.toc-title {
		font-weight: 650;
	}

	.toc-body {
		overflow: auto;
		padding-right: 4px;
		max-height: 100%;
		height: 100%;
		min-height: 0;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	.toc-body::-webkit-scrollbar {
		display: none;
	}

	.toc-float {
		display: none;
	}

	.toc-float-panel {
		display: none;
	}

	@media (max-width: 980px) {
		.toc-float {
			display: block;
		}

		.toc-float-btn {
			position: fixed;
			right: 12px;
			bottom: 84px;
			z-index: 95;
			height: 38px;
			padding: 0 14px;
			border-radius: 999px;
			border: 1px solid var(--border);
			background: color-mix(in oklab, var(--panel-strong), transparent 20%);
			backdrop-filter: blur(16px);
			color: var(--text);
			cursor: pointer;
		}

		.toc-float-btn:hover {
			border-color: color-mix(in oklab, var(--accent), var(--border) 35%);
		}

		.toc-float-panel {
			position: fixed;
			right: 12px;
			left: 12px;
			top: calc(var(--site-header-height, 72px) + 10px);
			bottom: 84px;
			z-index: 96;
			padding: 12px 14px;
			display: grid;
			grid-template-rows: auto 1fr;
			gap: 10px;
			background: color-mix(in oklab, var(--panel-strong), transparent 20%);
			backdrop-filter: blur(16px);
			overflow: hidden;
			opacity: 0;
			transform: translateY(10px);
			pointer-events: none;
			transition:
				opacity 180ms ease,
				transform 220ms ease;
		}

		.toc-float[data-open='1'] .toc-float-panel {
			opacity: 1;
			transform: translateY(0);
			pointer-events: auto;
		}

		.toc-float[data-open='1'] .toc-float-btn {
			opacity: 0;
			pointer-events: none;
		}

		.toc-float-head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 10px;
		}

		.toc-float-panel .toc-body {
			min-height: 0;
			overflow: auto;
			scrollbar-width: none;
			-ms-overflow-style: none;
		}

		.toc-float-panel .toc-body::-webkit-scrollbar {
			display: none;
		}
	}

	ul {
		margin: 0;
		padding-left: 16px;
		display: grid;
		gap: 8px;
	}

	li {
		list-style: none;
	}

	a {
		color: var(--muted);
		text-decoration: none;
	}

	a:hover {
		color: var(--text);
		text-decoration: underline;
		text-decoration-color: color-mix(in oklab, var(--accent), transparent 55%);
	}

	a.is-active {
		color: var(--text);
		font-weight: 650;
	}

	.d3 {
		padding-left: 10px;
	}

	.d4 {
		padding-left: 20px;
	}

	.empty {
		font-size: 13px;
		padding: 8px 2px;
	}
</style>

<script>
	import { pickActiveTocHeading } from '../utils/toc-active';

	const bindTocInteractions = () => {
		if ((window as any).__SITE_TOC_INTERACTION_BINDED__) return;
		(window as any).__SITE_TOC_INTERACTION_BINDED__ = true;

		const computeDrawerHeight = (panel: HTMLElement) => {
			const cap = Math.floor(window.innerHeight * 0.55);
			return Math.min(panel.scrollHeight, cap);
		};

		const setOpen = (root: Element, open: boolean) => {
			if (!(root instanceof HTMLElement)) return;
			root.dataset.open = open ? '1' : '0';
			const toggle = root.querySelector('[data-toc-toggle]');
			if (toggle instanceof HTMLButtonElement) {
				toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
			}
			const panel = root.querySelector('[data-toc-panel]');
			if (!(panel instanceof HTMLElement)) return;
			if (root.dataset.tocMode === 'drawer') {
				panel.style.maxHeight = open ? `${computeDrawerHeight(panel)}px` : '0px';
			} else {
				panel.setAttribute('aria-hidden', open ? 'false' : 'true');
			}
		};

		const syncAll = () => {
			document.querySelectorAll<HTMLElement>('[data-toc-root]').forEach((root) => {
				setOpen(root, root.dataset.open === '1');
			});
		};

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			const toggle = target.closest('[data-toc-toggle]');
			if (toggle) {
				const root = toggle.closest<HTMLElement>('[data-toc-root]');
				if (!root) return;
				setOpen(root, root.dataset.open !== '1');
				return;
			}
			const close = target.closest('[data-toc-close]');
			if (close) {
				const root = close.closest<HTMLElement>('[data-toc-root]');
				if (!root) return;
				setOpen(root, false);
				return;
			}
			const link = target.closest('[data-toc-root] a[data-toc-link]');
			if (link) {
				const root = link.closest<HTMLElement>('[data-toc-root]');
				if (root) setOpen(root, false);
			}
		});

		window.addEventListener('keydown', (event) => {
			if (event.key !== 'Escape') return;
			document.querySelectorAll<HTMLElement>('[data-toc-root]').forEach((root) => setOpen(root, false));
		});
		window.addEventListener('resize', syncAll);
		document.addEventListener('astro:page-load', syncAll);
		syncAll();
	};

	const run = () => {
		const settings = (window as any).__SITE_SETTINGS__;
		if (!settings?.site_features?.content?.tocEnhanced) return;
		const update = () => {
			const offset = Number((window as any).__SITE_SETTINGS__?.site_theme_tweaks?.tocActiveOffset ?? 96);
			const roots = Array.from(document.querySelectorAll<HTMLElement>('[data-toc-root]'));
			if (!roots.length) return;
			const headings = Array.from(document.querySelectorAll<HTMLElement>('.prose h2[id], .prose h3[id], .prose h4[id]'));
			const active = pickActiveTocHeading(
				headings.map((el) => ({ id: el.id, top: el.getBoundingClientRect().top })),
				offset
			);
			roots.forEach((root) => {
				root.querySelectorAll('a[data-toc-link]').forEach((a) => {
					const target = a.getAttribute('data-toc-link');
					a.classList.toggle('is-active', target === active);
				});
			});
		};

		(window as any).__SITE_TOC_ACTIVE_UPDATE__ = update;
		if (!(window as any).__SITE_TOC_ACTIVE_BINDED__) {
			(window as any).__SITE_TOC_ACTIVE_BINDED__ = true;
			window.addEventListener('scroll', () => (window as any).__SITE_TOC_ACTIVE_UPDATE__?.(), {
				passive: true,
			});
			window.addEventListener('resize', () => (window as any).__SITE_TOC_ACTIVE_UPDATE__?.());
			document.addEventListener('astro:page-load', () => {
				requestAnimationFrame(() => (window as any).__SITE_TOC_ACTIVE_UPDATE__?.());
			});
		}
		update();
	};

	if (document.readyState === 'loading') {
		document.addEventListener(
			'DOMContentLoaded',
			() => {
				bindTocInteractions();
				run();
			},
			{ once: true }
		);
	} else {
		bindTocInteractions();
		run();
	}
</script>
