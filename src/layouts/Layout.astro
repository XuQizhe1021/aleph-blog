---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import RewardPanel from '../components/RewardPanel.astro';
import SidebarWidgets from '../components/SidebarWidgets.astro';
import { siteConfig } from '../site.config';
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import { withBase } from '../utils/paths';
import { ClientRouter } from 'astro:transitions';
import { getSiteSettings } from '../config/site-settings';

type Props = {
	title?: string;
	description?: string;
};

const { title, description } = Astro.props;
const siteSettings = await getSiteSettings();
const pageTitle = title ? `${title} · ${siteConfig.title}` : siteConfig.title;
const pageDescription = description ?? siteConfig.description;
const analyticsBaseUrl = withBase('/');
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const vtDuration = `${siteSettings.site_theme_tweaks.viewTransitionDurationMs}ms`;
const vtEasing = siteSettings.site_theme_tweaks.viewTransitionEasing;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		{siteSettings.site_features.visual.viewTransitions ? <ClientRouter /> : null}
		<style is:inline>
			:root {
				--vt-duration: {vtDuration};
				--vt-easing: {vtEasing};
			}

			::view-transition-old(root),
			::view-transition-new(root) {
				animation-duration: var(--vt-duration);
				animation-timing-function: var(--vt-easing);
			}
		</style>
		<script is:inline>
			(() => {
				const key = 'theme';
				const stored = localStorage.getItem(key);
				const prefersDark =
					window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = stored ?? (prefersDark ? 'dark' : 'light');
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<script is:inline define:vars={{ analyticsBaseUrl }}>
			(() => {
				const isLocal =
					location.hostname === 'localhost' ||
					location.hostname === '127.0.0.1' ||
					location.hostname === '::1';
				if (isLocal) return;

				const sanitize = (s) =>
					String(s)
						.toLowerCase()
						.replace(/[^a-z0-9._-]/g, '_')
						.replace(/_+/g, '_')
						.replace(/^_+|_+$/g, '');

				const namespace = sanitize(location.hostname) || 'site';
				const key = sanitize(analyticsBaseUrl.replace(/\//g, '_')) || 'root';

				const setViews = (value) => {
					const text = typeof value === 'number' ? String(value) : '—';
					document.querySelectorAll('[data-site-views]').forEach((el) => {
						el.textContent = text;
					});
				};

				fetch(`https://api.countapi.xyz/hit/${namespace}/${key}`, { method: 'GET' })
					.then((r) => r.json())
					.then((data) => setViews(data?.value))
					.catch(() => setViews('—'));
			})();
		</script>
		<script is:inline define:vars={{ siteSettings }}>
			(() => {
				// 统一向客户端暴露配置，避免各组件分散硬编码。
				window.__SITE_SETTINGS__ = siteSettings;

				// 浏览器 API 降级保护：仅在客户端和开关开启时执行增强逻辑。
				const cfg = siteSettings;
				const text = cfg.site_texts || {};
				const features = cfg.site_features || {};
				const tweaks = cfg.site_theme_tweaks || {};

				const applyCursor = () => {
					if (!features?.visual?.customCursor) return;
					const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
					document.body.style.cursor = theme === 'dark' ? tweaks.cursorDark : tweaks.cursorLight;
				};
				const ensureCursorObserver = () => {
					if (window.__SITE_CURSOR_OBSERVED__) return;
					window.__SITE_CURSOR_OBSERVED__ = true;
					new MutationObserver(applyCursor).observe(document.documentElement, {
						attributes: true,
						attributeFilter: ['data-theme'],
					});
				};

				const enableCodeCopy = () => {
					if (!features?.content?.codeCopy) return;
					document.querySelectorAll('pre').forEach((pre) => {
						if (pre.querySelector('.code-copy-btn')) return;
						const code = pre.querySelector('code');
						if (!code) return;
						const btn = document.createElement('button');
						btn.type = 'button';
						btn.className = 'code-copy-btn';
						btn.textContent = text.copyCode || '复制';
						btn.addEventListener('click', async () => {
							try {
								await navigator.clipboard.writeText(code.textContent || '');
								btn.textContent = text.copySuccess || '已复制';
							} catch {
								btn.textContent = text.copyFailed || '复制失败';
							}
							window.setTimeout(() => {
								btn.textContent = text.copyCode || '复制';
							}, 1400);
						});
						pre.appendChild(btn);
					});
				};

				const enableMermaid = async () => {
					if (!features?.content?.mermaid) return;
					const nodes = Array.from(document.querySelectorAll('pre > code.language-mermaid'));
					if (!nodes.length) return;
					try {
						const mermaid = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
						mermaid.default.initialize({
							startOnLoad: false,
							theme: document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default',
							securityLevel: 'strict',
						});
						for (const code of nodes) {
							const pre = code.closest('pre');
							if (!pre) continue;
							const box = document.createElement('div');
							box.className = 'mermaid';
							box.textContent = code.textContent || '';
							pre.replaceWith(box);
						}
						await mermaid.default.run({
							nodes: Array.from(document.querySelectorAll('.mermaid')),
						});
					} catch {
						document.querySelectorAll('pre > code.language-mermaid').forEach((code) => {
							const hint = document.createElement('div');
							hint.className = 'mermaid-fallback muted';
							hint.textContent = text.mermaidFallback || '图表渲染失败';
							code.closest('pre')?.insertAdjacentElement('afterend', hint);
						});
					}
				};
				enableMermaid();

				const matchDate = (mmdd, today) => {
					if (!/^\d{2}-\d{2}$/.test(mmdd || '')) return false;
					return mmdd === today;
				};

				const showFestival = () => {
					if (!features?.visual?.festivalEffect) return;
					if (document.body?.dataset?.festivalShown === '1') return;
					const now = new Date();
					const mmdd = `${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
					const start = tweaks.festivalStartDate;
					const end = tweaks.festivalEndDate;
					if (!(matchDate(start, mmdd) || matchDate(end, mmdd))) return;
					const el = document.createElement('div');
					el.className = 'festival-effect';
					document.body.appendChild(el);
					document.body.dataset.festivalShown = '1';
					window.setTimeout(() => el.remove(), Number(tweaks.festivalDurationMs || 1800));
				};

				// Astro 页面切换后会重新渲染正文，这里统一在每次页面就绪时执行增强逻辑。
				const runEnhancements = () => {
					applyCursor();
					ensureCursorObserver();
					enableCodeCopy();
					void enableMermaid();
					showFestival();
				};

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', runEnhancements, { once: true });
				} else {
					runEnhancements();
				}
				document.addEventListener('astro:page-load', runEnhancements);
			})();
		</script>
	</head>
	<body>
		<div class="app-shell">
			<SiteHeader />
			<main class="app-main">
				<slot />
			</main>
			<SiteFooter />
			<RewardPanel />
			<SidebarWidgets />
		</div>
	</body>
</html>
