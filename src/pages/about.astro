---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site.config';
---

<Layout title="关于">
	<section class="panel about">
		<h1>关于</h1>
		<p class="muted">
			这里是 <strong>{siteConfig.author}</strong> 的个人博客。你可以在这里阅读文章、搜索、按分类浏览。
		</p>
		<p class="muted">
			如果你喜欢我的博客风格，欢迎你使用我的开源项目<a href="https://github.com/XuQizhe1021/aleph-blog">aleph-blog</a>，欢迎你贡献代码。	
		</p>
	</section>
</Layout>

<style>
	.about {
		padding: 18px;
	}

	h1 {
		margin: 0 0 10px;
	}
</style>

