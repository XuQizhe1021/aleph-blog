---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublicPosts, getAllCategories, getPostActivityDate } from '../../utils/blog';
import { withBase } from '../../utils/paths';

const posts = await getPublicPosts();
const categories = getAllCategories(posts);
const postSortMeta = posts.map((post) => ({
	slug: post.slug,
	title: post.data.title,
	pubTime: post.data.pubDate.getTime(),
	activityTime: getPostActivityDate(post).getTime(),
}));
---

<Layout title="文章">
	<section class="head panel">
		<div class="head-left">
			<div class="title">文章</div>
			<div class="muted">共 {posts.length} 篇</div>
		</div>
		<div class="pager" id="pager" hidden>
			<button class="btn" id="prev" type="button">上一页</button>
			<div class="muted" id="page-info"></div>
			<button class="btn" id="next" type="button">下一页</button>
		</div>
	</section>

	<section class="filters panel">
		<div class="filter-head">
			<div class="label muted">分类</div>
			<div class="sort-switch" aria-label="排序方式">
				<button class="sort-chip is-active" type="button" data-sort-toggle="latest">最新</button>
				<button class="sort-chip" type="button" data-sort-toggle="updated">最近更新</button>
				<button class="sort-chip" type="button" data-sort-toggle="title">标题</button>
			</div>
		</div>
		<div class="chips">
			<a class="chip" href={withBase('/posts')}>全部</a>
			{categories.map((c) => (
				<a class="chip" href={withBase(`/categories/${encodeURIComponent(c.category)}`)}>
					{c.category} <span class="muted">({c.count})</span>
				</a>
			))}
		</div>
	</section>

	<section class="list" id="paged-list">
		{posts.length ? (
			posts.map((post, index) => (
				<div
					class="post-item"
					data-title={postSortMeta[index]?.title.toLocaleLowerCase('zh-CN')}
					data-pub={String(postSortMeta[index]?.pubTime ?? 0)}
					data-updated={String(postSortMeta[index]?.activityTime ?? 0)}
				>
					<PostCard post={post} />
				</div>
			))
		) : (
			<div class="muted">暂无文章</div>
		)}
	</section>

	<script is:inline>
		(() => {
			const list = document.getElementById('paged-list');
			const pager = document.getElementById('pager');
			const prev = document.getElementById('prev');
			const next = document.getElementById('next');
			const info = document.getElementById('page-info');
			const sortButtons = Array.from(
				document.querySelectorAll('[data-sort-toggle]')
			).filter((el) => el instanceof HTMLButtonElement);
			if (!list || !pager || !prev || !next || !info) return;

			const items = Array.from(list.children).filter((el) => el instanceof HTMLElement);
			if (items.length <= 1) return;

			let pageSize = 10;
			let page = 0;
			let pageCount = 1;
			let sortMode = 'latest';

			const computePageSize = () => (matchMedia('(max-width: 720px)').matches ? 6 : 10);
			const parseNumber = (value) => Number(value || 0);
			const syncSortButtons = () => {
				sortButtons.forEach((btn) => {
					const active = btn.dataset.sortToggle === sortMode;
					btn.classList.toggle('is-active', active);
					btn.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
			};
			const applySort = () => {
				const sorted = items.slice().sort((a, b) => {
					if (sortMode === 'title') {
						return (a.dataset.title || '').localeCompare(b.dataset.title || '', 'zh-CN');
					}
					if (sortMode === 'updated') {
						return parseNumber(b.dataset.updated) - parseNumber(a.dataset.updated);
					}
					return parseNumber(b.dataset.pub) - parseNumber(a.dataset.pub);
				});
				sorted.forEach((el) => list.appendChild(el));
				syncSortButtons();
			};

			const apply = () => {
				applySort();
				pageSize = computePageSize();
				pageCount = Math.max(1, Math.ceil(items.length / pageSize));
				page = Math.min(page, pageCount - 1);
				const start = page * pageSize;
				const end = start + pageSize;
				items.forEach((el, i) => (el.style.display = i >= start && i < end ? '' : 'none'));
				info.textContent = `${page + 1} / ${pageCount}`;
				prev.disabled = page <= 0;
				next.disabled = page >= pageCount - 1;
				pager.hidden = pageCount <= 1;
			};

			// 排序切换后回到第一页，保持浏览节奏稳定。
			sortButtons.forEach((btn) => {
				btn.addEventListener('click', () => {
					const nextMode = btn.dataset.sortToggle || 'latest';
					if (nextMode === sortMode) return;
					sortMode = nextMode;
					page = 0;
					const url = new URL(window.location.href);
					url.searchParams.set('sort', sortMode);
					history.replaceState(null, '', url);
					apply();
				});
			});
			prev.addEventListener('click', () => {
				page = Math.max(0, page - 1);
				apply();
			});
			next.addEventListener('click', () => {
				page = Math.min(pageCount - 1, page + 1);
				apply();
			});

			let t = 0;
			window.addEventListener('resize', () => {
				window.clearTimeout(t);
				t = window.setTimeout(() => apply(), 120);
			});

			const initialSort = new URL(window.location.href).searchParams.get('sort');
			if (initialSort === 'updated' || initialSort === 'title' || initialSort === 'latest') {
				sortMode = initialSort;
			}
			apply();
		})();
	</script>
</Layout>

<style>
	.head {
		padding: 18px;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 12px;
		align-items: center;
		position: sticky;
		top: 72px;
		z-index: 80;
		gap: 10px;
	}

	.title {
		font-size: 24px;
		font-weight: 800;
	}
	.head-left {
		display: grid;
		gap: 6px;
	}


	.filters {
		padding: 14px;
		display: grid;
		gap: 10px;
	}

	.filter-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
	}

	.chips {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		height: 30px;
		padding: 0 10px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 18%);
		color: var(--text);
		text-decoration: none;
		font-size: 13px;
	}

	.chip:hover {
		text-decoration: none;
		border-color: color-mix(in oklab, var(--accent), var(--border) 30%);
	}

	.sort-switch {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 18%);
	}

	.sort-chip {
		height: 28px;
		padding: 0 12px;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		font-size: 12px;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			box-shadow 180ms ease;
	}

	.sort-chip:hover {
		color: var(--text);
	}

	.sort-chip.is-active {
		color: var(--text);
		background:
			linear-gradient(
				90deg,
				color-mix(in oklab, var(--accent), transparent 18%),
				color-mix(in oklab, var(--accent2), transparent 28%)
			);
		box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--panel-strong), transparent 20%);
	}

	.list {
		margin-top: 14px;
		display: grid;
		gap: 12px;
	}

	.pager {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	@media (max-width: 720px) {
		.head {
			grid-template-columns: 1fr;
			align-items: start;
		}
		.filter-head {
			align-items: start;
		}
		.sort-switch {
			width: 100%;
			justify-content: space-between;
		}
		.pager {
			width: 100%;
		}
	}
</style>
