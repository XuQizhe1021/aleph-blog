---
import Layout from '../layouts/Layout.astro';
import { getPublicPosts, getPostActivityDate, getPrimaryCategory } from '../utils/blog';
import { withBase } from '../utils/paths';
import { getSiteSettings } from '../config/site-settings';

const settings = await getSiteSettings();
const posts = await getPublicPosts();
const rows = posts
	.map((post) => {
		const date = getPostActivityDate(post);
		const year = String(date.getFullYear());
		const month = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
		return {
			slug: post.slug,
			title: post.data.title,
			date,
			year,
			month,
			category: getPrimaryCategory(post),
		};
	})
	.sort((a, b) => b.date.getTime() - a.date.getTime() || a.title.localeCompare(b.title, 'zh-CN'));
const yearMap = new Map<
	string,
	{
		year: string;
		anchorId: string;
		total: number;
		months: Array<{
			key: string;
			label: string;
			total: number;
			rows: typeof rows;
		}>;
	}
>();

for (const row of rows) {
	const yearKey = row.year;
	const monthKey = row.month;
	let yearBucket = yearMap.get(yearKey);
	if (!yearBucket) {
		yearBucket = {
			year: yearKey,
			anchorId: `year-${yearKey}`,
			total: 0,
			months: [],
		};
		yearMap.set(yearKey, yearBucket);
	}
	yearBucket.total += 1;
	let monthBucket = yearBucket.months.find((item) => item.key === monthKey);
	if (!monthBucket) {
		monthBucket = {
			key: monthKey,
			label: new Date(`${monthKey}-01T00:00:00`).toLocaleDateString('zh-CN', {
				month: 'long',
			}),
			total: 0,
			rows: [],
		};
		yearBucket.months.push(monthBucket);
	}
	monthBucket.total += 1;
	monthBucket.rows.push(row);
}

const timelineGroups = [...yearMap.values()].sort((a, b) => Number(b.year) - Number(a.year));
for (const group of timelineGroups) {
	group.months.sort((a, b) => b.key.localeCompare(a.key));
}
---

<Layout title="时光机">
	<section class="panel tm">
		<div class="head">
			<h1>时光机</h1>
			<div class="muted">按时间轴浏览文章</div>
		</div>
		{
			settings.site_features.tools.timeMachine ? (
				<>
					<nav class="year-nav" aria-label="年份锚点">
						{timelineGroups.map((group) => (
							<a class="year-anchor" href={`#${group.anchorId}`}>
								<span>{group.year}</span>
								<span class="year-anchor-count muted">{group.total}</span>
							</a>
						))}
					</nav>
					<div class="timeline">
						{timelineGroups.map((group, groupIndex) => (
							<section class="year-block" id={group.anchorId}>
								<div class="year-title-row">
									<h2 class="year-title">{group.year}</h2>
									<div class="muted">{group.total} 篇</div>
								</div>
								<div class="month-stack">
									{group.months.map((month, monthIndex) => (
										<details class="month-group" open={groupIndex === 0 && monthIndex === 0}>
											<summary class="month-summary">
												<span class="month-label">{month.label}</span>
												<span class="month-meta muted">{month.total} 条记录</span>
											</summary>
											<div class="month-list">
												{month.rows.map((row) => (
													<a class="item panel" href={`${withBase('/posts')}/${encodeURIComponent(row.slug)}`}>
														<div class="item-main">
															<div class="title">{row.title}</div>
															<div class="item-date muted">
																{row.date.toLocaleDateString('zh-CN')} · {row.category}
															</div>
														</div>
													</a>
												))}
											</div>
										</details>
									))}
								</div>
							</section>
						))}
					</div>
				</>
			) : (
				<div class="muted">该功能已在后台关闭。</div>
			)
		}
	</section>
</Layout>

<style>
	.tm {
		padding: 18px;
		display: grid;
		gap: 12px;
	}

	.head {
		display: grid;
		gap: 6px;
	}

	h1 {
		margin: 0;
	}

	.year-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.year-anchor {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		height: 30px;
		padding: 0 12px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: color-mix(in oklab, var(--panel-strong), transparent 18%);
		text-decoration: none;
		font-size: 13px;
	}

	.year-anchor:hover {
		text-decoration: none;
		border-color: color-mix(in oklab, var(--accent), var(--border) 34%);
	}

	.year-anchor-count {
		font-size: 12px;
	}

	.timeline {
		display: grid;
		gap: 18px;
	}

	.year-block {
		display: grid;
		gap: 12px;
		scroll-margin-top: 92px;
	}

	.year-title-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 12px;
		padding-top: 4px;
	}

	.year-title {
		margin: 0;
		font-size: 22px;
	}

	.month-stack {
		display: grid;
		gap: 10px;
	}

	.month-group {
		border: 1px solid var(--border);
		border-radius: 16px;
		background: color-mix(in oklab, var(--panel-strong), transparent 20%);
		overflow: hidden;
	}

	.month-summary {
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 14px 16px;
		cursor: pointer;
	}

	.month-summary::-webkit-details-marker {
		display: none;
	}

	.month-summary::after {
		content: '';
		width: 8px;
		height: 8px;
		border-right: 1.5px solid currentColor;
		border-bottom: 1.5px solid currentColor;
		transform: rotate(45deg);
		opacity: 0.55;
		transition: transform 180ms ease;
	}

	.month-group[open] .month-summary::after {
		transform: rotate(225deg);
	}

	.month-label {
		font-weight: 650;
	}

	.month-meta {
		margin-left: auto;
		font-size: 12px;
	}

	.item {
		padding: 14px;
		display: grid;
		gap: 6px;
		text-decoration: none;
	}

	.title {
		font-weight: 700;
	}

	.month-list {
		display: grid;
		gap: 10px;
		padding: 0 12px 12px;
	}

	.item-main {
		display: grid;
		gap: 6px;
	}

	.item-date {
		font-size: 13px;
	}

	@media (max-width: 720px) {
		.month-summary {
			padding: 12px 14px;
		}
		.year-title-row {
			flex-direction: column;
			align-items: start;
			gap: 4px;
		}
	}
</style>
